{
  "name": "vitepress-plugin-group-icons",
  "version": "1.7.5",
  "keywords": [
    "vitepress",
    "vitepress-plugin"
  ],
  "homepage": "https://github.com/yuyinws/vitepress-plugin-group-icons#readme",
  "bugs": "https://github.com/yuyinws/vitepress-plugin-group-icons/issues",
  "license": "MIT",
  "author": "Leo <https://github.com/yuyinws>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yuyinws/vitepress-plugin-group-icons.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./dist/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "dependencies": {
    "@iconify-json/logos": "^1.2.10",
    "@iconify-json/vscode-icons": "^1.2.45",
    "@iconify/utils": "^3.1.0"
  },
  "devDependencies": {
    "@antfu/ni": "^30.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.5.0",
    "bumpp": "^11.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "vite-plus": "^0.1.14",
    "vitepress": "^1.6.4"
  },
  "peerDependencies": {
    "vite": ">=3"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "scripts": {
    "build": "vp pack",
    "dev": "pnpm build --watch",
    "lint:fix": "vp lint --fix && vp fmt",
    "lint": "vp lint",
    "release": "bumpp",
    "test": "vp test",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  }
}